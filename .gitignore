# --- macOS ---
.DS_Store

# --- Rust (core/) ---
# ビルド成果物。再生成可能なのでコミットしない。
target/
**/*.rs.bk
# Cargo.lock は意図的に追跡する（アプリのため再現性を優先）。

# --- Android（今後）---
# Gradle / ビルド成果物・ローカル設定・NDK 中間生成物。
.gradle/
build/
**/build/
local.properties
.cxx/
captures/
.externalNativeBuild/
# Kotlin Gradle プラグインのビルドキャッシュ/ログ。
.kotlin/
# Rust から生成する .so（hack/build-rust-android.sh が再生成するので追跡しない）。
**/jniLibs/
# UniFFI が生成する Kotlin バインディングはビルド時生成物。再生成するなら無視。
# （生成物をコミットする運用に切り替えるなら、この行を外す）
# **/generated/uniffi/

# --- iOS / Xcode（後続）---
xcuserdata/
**/*.xcuserstate
DerivedData/
.swiftpm/
Pods/

# --- IDE / エディタ ---
.idea/
*.iml
.vscode/

# --- Claude Code ---
# 設定は個人・マシン依存（絶対パスや個人 skill 許可など）になりやすいため追跡しない。
# ただしプロジェクト共有のスキル（.claude/skills/）は追跡し、チームで再利用する。
.claude/*
!.claude/skills/

# --- 環境・秘匿情報 ---
.env
